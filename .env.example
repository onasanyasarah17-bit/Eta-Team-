# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Server Configuration
PORT=5000
HOST=0.0.0.0

# AWS Configuration
# NOTE: Do NOT set AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY
# On EC2, boto3 will automatically detect the attached IAM Role
# Credentials will be obtained from the IAM Role, not from environment variables
AWS_REGION=eu-north-1

# DynamoDB Configuration
DYNAMODB_TABLE_NAME=secure-employees

# Logging
LOG_LEVEL=INFO
# JSON logs are recommended in production for CloudWatch Logs Insights
LOG_JSON=false
# Optional rotating file log (leave unset to log to stdout only)
# LOG_FILE=/var/log/secure-employee-directory/app.log

# Reverse proxy / ALB (set true in production behind an Application Load Balancer)
TRUST_PROXY=false
